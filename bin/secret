#!/bin/bash
# Fetch a secret from an isolated macOS Keychain by name.
# Usage: secret <NAME>
# Inline use: curl -H "Authorization: Bearer $(secret STRIPE_PROD)" ...
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

resolve_repo_root() {
  local self target

  self="${BASH_SOURCE[0]}"
  while [ -L "$self" ]; do
    target="$(readlink "$self")"
    case "$target" in
      /*) self="$target" ;;
      *)  self="$(cd -P "$(dirname "$self")" && pwd)/$target" ;;
    esac
  done

  cd -P "$(dirname "$self")/.." && pwd
}

print_version() {
  local repo ver branch sha

  repo="${SECRET_REPO:-$(resolve_repo_root)}"
  if [ ! -d "$repo/.git" ]; then
    echo "unknown"
    return 0
  fi

  ver="$(git -C "$repo" describe --tags --exact-match 2>/dev/null || true)"
  if [ -n "$ver" ]; then
    echo "$ver"
    return 0
  fi

  branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  sha="$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || true)"
  if [ "$branch" = "master" ]; then
    echo "master@$sha"
  elif [ "$branch" = "HEAD" ]; then
    echo "unknown@$sha"
  else
    echo "$branch@$sha"
  fi
}

usage() {
  cat >&2 <<'EOF'
usage: secret <NAME>            fetch a secret's value to stdout
       secret --version         print the installed version
       secret --help            show this help

Fetch inline so the value never lands in shell history or a file:
  curl -H "Authorization: Bearer $(secret STRIPE_PROD)" https://api.example.com

Related commands:
  secret-list     list stored names (never values)
  secret-add      add or update a secret (prompted)
  secret-paste    store a secret from the clipboard
  secret-rm       remove a secret
  secret-rotate   replace a value, archiving the old one
  secret-load     bulk-load KEY=value pairs from a file
  secret-config   set the keychain auto-lock timeout
  secret-audit    show the fetch/audit log
  secret-init     create the isolated keychain (run once)
EOF
}

case "${1:-}" in
  --version|-V)
    print_version
    exit 0
    ;;
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  usage
  exit 64
fi

name="$1"

# Audit log: name only, never the value. Best-effort; never fail the fetch.
{
  state_dir="${SECRET_STATE_DIR:-$HOME/.claude/state}"
  mkdir -p "$state_dir" 2>/dev/null || true
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  pcomm="$(ps -o comm= -p "$PPID" 2>/dev/null | tr -d ' ' || true)"
  : "${pcomm:=unknown}"
  ( printf '%s secret=%s ppid=%s pcomm=%s\n' "$ts" "$name" "$PPID" "$pcomm" \
    >> "$state_dir/secret-fetch.log" ) 2>/dev/null || true
} 2>/dev/null || true

if ! security find-generic-password -a "$USER" -s "$name" -w "$keychain" 2>/dev/null; then
  # Inline color (this hot-path command stays dependency-free): red on a TTY,
  # plain when piped/redirected or NO_COLOR is set.
  if [ -t 2 ] && [ -z "${NO_COLOR:-}" ]; then r=$'\033[31m'; d=$'\033[2m'; x=$'\033[0m'; else r=''; d=''; x=''; fi
  printf '%ssecret: '\''%s'\'' not found in %s%s\n' "$r" "$name" "$keychain" "$x" >&2
  printf '%s  add with: secret-add %s%s\n' "$d" "$name" "$x" >&2
  exit 1
fi
