#!/bin/bash
# Fetch a secret from an isolated macOS Keychain by name.
# Usage: secret <NAME>
# Inline use: curl -H "Authorization: Bearer $(secret STRIPE_PROD)" ...
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

resolve_repo_root() {
  local self target

  self="${BASH_SOURCE[0]}"
  while [ -L "$self" ]; do
    target="$(readlink "$self")"
    case "$target" in
      /*) self="$target" ;;
      *)  self="$(cd -P "$(dirname "$self")" && pwd)/$target" ;;
    esac
  done

  cd -P "$(dirname "$self")/.." && pwd
}

print_version() {
  local repo ver branch sha

  repo="${SECRET_REPO:-$(resolve_repo_root)}"
  if [ ! -d "$repo/.git" ]; then
    echo "unknown"
    return 0
  fi

  ver="$(git -C "$repo" describe --tags --exact-match 2>/dev/null || true)"
  if [ -n "$ver" ]; then
    echo "$ver"
    return 0
  fi

  branch="$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  sha="$(git -C "$repo" rev-parse --short HEAD 2>/dev/null || true)"
  if [ "$branch" = "master" ]; then
    echo "master@$sha"
  elif [ "$branch" = "HEAD" ]; then
    echo "unknown@$sha"
  else
    echo "$branch@$sha"
  fi
}

case "${1:-}" in
  --version|-V)
    print_version
    exit 0
    ;;
esac

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  echo "usage: secret <NAME>" >&2
  echo "       (list names with: secret-list)" >&2
  exit 64
fi

name="$1"

# Audit log: name only, never the value. Best-effort; never fail the fetch.
{
  state_dir="${SECRET_STATE_DIR:-$HOME/.claude/state}"
  mkdir -p "$state_dir" 2>/dev/null || true
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  pcomm="$(ps -o comm= -p "$PPID" 2>/dev/null | tr -d ' ' || true)"
  : "${pcomm:=unknown}"
  ( printf '%s secret=%s ppid=%s pcomm=%s\n' "$ts" "$name" "$PPID" "$pcomm" \
    >> "$state_dir/secret-fetch.log" ) 2>/dev/null || true
} 2>/dev/null || true

if ! security find-generic-password -a "$USER" -s "$name" -w "$keychain" 2>/dev/null; then
  echo "secret: '$name' not found in $keychain" >&2
  echo "  add with: secret-add $name" >&2
  exit 1
fi
