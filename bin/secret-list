#!/bin/bash
# List secret names stored in the isolated keychain (default: ai.keychain).
# Only prints service names — never values.
# Usage: secret-list
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

case "${1:-}" in
  -h|--help)
    echo "usage: secret-list   list stored secret names (never values)" >&2
    exit 0
    ;;
esac

names="$(security dump-keychain "$keychain" 2>/dev/null \
  | awk -F'"' '/"svce"<blob>=/{print $4}' \
  | sort -u)"

if [ -z "$names" ]; then
  ui_info "(no secrets stored in $keychain)"
  exit 0
fi

# Names to stdout (pipeable); count to stderr so `secret-list | grep` is clean.
printf '%s\n' "$names"
ui_hint "$(printf '%s\n' "$names" | grep -c .) secret(s) in $keychain"
