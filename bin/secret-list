#!/bin/bash
# List secret names stored in the isolated keychain (default: ai.keychain).
# Only prints service names — never values.
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

security dump-keychain "$keychain" 2>/dev/null \
  | awk -F'"' '/"svce"<blob>=/{print $4}' \
  | sort -u
