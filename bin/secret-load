#!/bin/bash
# Bulk-load KEY=value pairs into the isolated keychain without printing values.
# Usage: secret-load <env-file>
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

case "${1:-}" in
  -h|--help)
    echo "usage: secret-load <env-file>   bulk-load KEY=value pairs (values never printed)" >&2
    exit 0
    ;;
esac

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  echo "usage: secret-load <env-file>" >&2
  exit 64
fi

file="$1"
if [ ! -r "$file" ]; then
  ui_err "secret-load: cannot read $file"
  exit 66
fi

pass=0
skip=0
fail=0

while IFS= read -r line || [ -n "$line" ]; do
  trimmed="$(printf '%s' "$line" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
  [ -z "$trimmed" ] && continue
  case "$trimmed" in
    \#*) continue ;;
  esac

  key="${trimmed%%=*}"
  value="${trimmed#*=}"

  if [ "$key" = "$trimmed" ] || [ -z "$key" ]; then
    ui_err "FAIL malformed line (no =): ${trimmed:0:40}..."
    fail=$((fail + 1))
    continue
  fi

  case "$value" in
    \"*\")
      value="${value#\"}"
      value="${value%\"}"
      ;;
    \'*\')
      value="${value#\'}"
      value="${value%\'}"
      ;;
  esac

  if [ -z "$value" ] || [ "$value" = "PLACEHOLDER" ] || [ "$value" = "TODO" ] || [[ "$value" =~ ^\<.*\>$ ]]; then
    ui_warn "SKIP $key (placeholder)"
    skip=$((skip + 1))
    continue
  fi

  if security add-generic-password -U -a "$USER" -s "$key" -w "$value" "$keychain" >/dev/null 2>&1; then
    ui_ok "PASS $key"
    pass=$((pass + 1))
  else
    status=$?
    ui_err "FAIL $key (security command exit $status)"
    fail=$((fail + 1))
  fi
done < "$file"

echo >&2
if [ "$fail" -gt 0 ]; then
  ui_warn "Loaded: $pass  skipped: $skip  failed: $fail"
else
  ui_ok "Loaded: $pass  skipped: $skip  failed: $fail"
fi
if [ "$pass" -gt 0 ]; then
  echo >&2
  ui_hint "Verify with:  secret-list | grep <KEY>"
  ui_hint "Delete the source file when done:  rm -P \"$file\"   (overwrites then unlinks)"
fi
