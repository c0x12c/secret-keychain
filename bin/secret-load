#!/bin/bash
# Bulk-load KEY=value pairs into the isolated keychain without printing values.
# Usage: secret-load <env-file>
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  echo "usage: secret-load <env-file>" >&2
  exit 64
fi

file="$1"
if [ ! -r "$file" ]; then
  echo "secret-load: cannot read $file" >&2
  exit 66
fi

pass=0
skip=0
fail=0

while IFS= read -r line || [ -n "$line" ]; do
  trimmed="$(printf '%s' "$line" | sed -E 's/^[[:space:]]+//; s/[[:space:]]+$//')"
  [ -z "$trimmed" ] && continue
  case "$trimmed" in
    \#*) continue ;;
  esac

  key="${trimmed%%=*}"
  value="${trimmed#*=}"

  if [ "$key" = "$trimmed" ] || [ -z "$key" ]; then
    echo "FAIL malformed line (no =): ${trimmed:0:40}..." >&2
    fail=$((fail + 1))
    continue
  fi

  case "$value" in
    \"*\")
      value="${value#\"}"
      value="${value%\"}"
      ;;
    \'*\')
      value="${value#\'}"
      value="${value%\'}"
      ;;
  esac

  if [ -z "$value" ] || [ "$value" = "PLACEHOLDER" ] || [ "$value" = "TODO" ] || [[ "$value" =~ ^\<.*\>$ ]]; then
    echo "SKIP $key (placeholder)" >&2
    skip=$((skip + 1))
    continue
  fi

  if security add-generic-password -U -a "$USER" -s "$key" -w "$value" "$keychain" >/dev/null 2>&1; then
    echo "PASS $key" >&2
    pass=$((pass + 1))
  else
    status=$?
    echo "FAIL $key (security command exit $status)" >&2
    fail=$((fail + 1))
  fi
done < "$file"

echo >&2
echo "Loaded: $pass  skipped: $skip  failed: $fail" >&2
if [ "$pass" -gt 0 ]; then
  echo >&2
  echo "Verify with:  secret-list | grep <KEY>" >&2
  echo "Delete the source file when done:  rm -P \"$file\"   (overwrites then unlinks)" >&2
fi
