#!/bin/bash
# Pull the latest secret-keychain from its git remote and re-link the binaries.
# Usage: secret-upgrade                  (uses the repo this script was installed from)
#        SECRET_REPO=/path ./secret-upgrade
# Env:
#   SECRET_REPO  override the repo root (default: the repo containing this script).
#   PREFIX       passed through to install.sh (default: ~/.local/bin).
#
# Safety: refuses to pull if the working tree is dirty (uncommitted edits) or if
# the upstream branch has diverged — those are local-fork situations the human
# should resolve. Refuses to operate on a non-git checkout (e.g. tarball install).
set -euo pipefail

# Resolve the real repo root by following the install symlink back to the
# `bin/secret-upgrade` source in the cloned repo.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
  target="$(readlink "$self")"
  case "$target" in
    /*) self="$target" ;;
    *)  self="$(cd -P "$(dirname "$self")" && pwd)/$target" ;;
  esac
done
repo="${SECRET_REPO:-$(cd -P "$(dirname "$self")/.." && pwd)}"

if [ ! -d "$repo/.git" ]; then
  echo "secret-upgrade: $repo is not a git checkout — re-clone manually:" >&2
  echo "  git clone https://github.com/c0x12c/secret-keychain.git" >&2
  exit 1
fi

cd "$repo"

# Refuse on dirty tree — protects local edits.
if ! git diff --quiet || ! git diff --cached --quiet; then
  echo "secret-upgrade: working tree at $repo has uncommitted changes; aborting." >&2
  echo "  commit or stash your edits, then re-run secret-upgrade." >&2
  exit 1
fi

branch="$(git rev-parse --abbrev-ref HEAD)"
echo "fetching origin…" >&2
git fetch --quiet origin "$branch"

local_sha="$(git rev-parse "@")"
remote_sha="$(git rev-parse "@{u}" 2>/dev/null || echo "")"
if [ -z "$remote_sha" ]; then
  echo "secret-upgrade: branch $branch has no upstream; aborting." >&2
  exit 1
fi

if [ "$local_sha" = "$remote_sha" ]; then
  echo "already up to date ($local_sha on $branch)" >&2
  exit 0
fi

base_sha="$(git merge-base "@" "@{u}")"
if [ "$base_sha" != "$local_sha" ]; then
  echo "secret-upgrade: local branch $branch has diverged from origin." >&2
  echo "  resolve manually (git pull --rebase / git log @..@{u})." >&2
  exit 1
fi

old_sha="$local_sha"
git pull --ff-only --quiet origin "$branch"
new_sha="$(git rev-parse HEAD)"

# Re-run the installer to refresh symlinks (in case new commands were added).
PREFIX="${PREFIX:-$HOME/.local/bin}" bash "$repo/install.sh" >/dev/null

echo "upgraded: ${old_sha:0:9} -> ${new_sha:0:9} on $branch" >&2
echo "changelog:" >&2
git log --oneline "$old_sha..$new_sha" >&2 || true
