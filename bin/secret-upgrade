#!/bin/bash
# Pull the latest secret-keychain from its git remote and re-link the binaries.
# Usage: secret-upgrade                  (uses the repo this script was installed from)
#        SECRET_REPO=/path ./secret-upgrade
# Env:
#   SECRET_REPO           override the repo root (default: the repo containing this script).
#   SECRET_UPGRADE_TRACK  set to master to follow master instead of released tags.
#   PREFIX                passed through to install.sh (default: ~/.local/bin).
#
# Safety: refuses to move if the working tree is dirty or if the user is on a
# named non-master branch. Refuses to operate on a non-git checkout.
set -euo pipefail

# Resolve the real repo root by following the install symlink back to the
# `bin/secret-upgrade` source in the cloned repo.
self="${BASH_SOURCE[0]}"
while [ -L "$self" ]; do
  target="$(readlink "$self")"
  case "$target" in
    /*) self="$target" ;;
    *)  self="$(cd -P "$(dirname "$self")" && pwd)/$target" ;;
  esac
done
repo="${SECRET_REPO:-$(cd -P "$(dirname "$self")/.." && pwd)}"

# Shared UI helpers, with plain-echo fallbacks if the lib is unavailable.
if [ -f "$repo/lib/ui.sh" ]; then
  # shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
  . "$repo/lib/ui.sh"
else
  ui_ok()   { printf '%s\n' "$*" >&2; }
  ui_err()  { printf '%s\n' "$*" >&2; }
  ui_info() { printf '%s\n' "$*" >&2; }
fi

case "${1:-}" in
  -h|--help)
    cat >&2 <<'EOF'
usage: secret-upgrade [--track master | --ref <ref>]
  (no flag)        move to the latest released tag
  --track master   follow the master branch instead of tags
  --ref <ref>      check out a specific tag/branch/commit
Refuses to move on a dirty tree or a named non-master branch.
EOF
    exit 0
    ;;
esac

if [ ! -d "$repo/.git" ]; then
  echo "secret-upgrade: $repo is not a git checkout — re-clone manually:" >&2
  echo "  git clone https://github.com/c0x12c/secret-keychain.git" >&2
  exit 1
fi

mode="tag"
ref=""

while [ $# -gt 0 ]; do
  case "$1" in
    --track)
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "secret-upgrade: --track requires a value" >&2
        exit 64
      fi
      if [ "$2" != "master" ]; then
        echo "secret-upgrade: only '--track master' is supported" >&2
        exit 64
      fi
      mode="master"
      shift 2
      ;;
    --ref)
      if [ $# -lt 2 ] || [ -z "${2:-}" ]; then
        echo "secret-upgrade: --ref requires a value" >&2
        exit 64
      fi
      mode="ref"
      ref="$2"
      shift 2
      ;;
    *)
      echo "secret-upgrade: unknown argument: $1" >&2
      exit 64
      ;;
  esac
done

if [ "${SECRET_UPGRADE_TRACK:-}" = "master" ]; then
  mode="master"
fi

cd "$repo"

# Refuse on dirty tree — protects local edits.
if ! git diff --quiet || ! git diff --cached --quiet; then
  ui_err "secret-upgrade: working tree at $repo has uncommitted changes; aborting."
  echo "  commit or stash your edits, then re-run secret-upgrade." >&2
  exit 1
fi

branch="$(git rev-parse --abbrev-ref HEAD)"

if [ "$branch" != "HEAD" ] && [ "$branch" != "master" ]; then
  ui_err "secret-upgrade: on branch $branch; refusing to move your work. Use --track master, --ref, or switch branches."
  exit 1
fi

refresh_symlinks() {
  SKIP_CHECKOUT=1 PREFIX="${PREFIX:-$HOME/.local/bin}" bash "$repo/install.sh" >/dev/null
}

latest_tag() {
  git tag --list 'v[0-9]*.[0-9]*.[0-9]*' --sort=-v:refname | head -1
}

if [ "$mode" = "master" ]; then
  if [ "$branch" != "master" ]; then
    git checkout --quiet master
  fi

  git fetch --quiet origin master
  local_sha="$(git rev-parse "@")"
  remote_sha="$(git rev-parse "@{u}" 2>/dev/null || echo "")"
  if [ -z "$remote_sha" ]; then
    ui_err "secret-upgrade: branch master has no upstream; aborting."
    exit 1
  fi

  if [ "$local_sha" = "$remote_sha" ]; then
    ui_ok "already up to date"
    refresh_symlinks
    exit 0
  fi

  base_sha="$(git merge-base "@" "@{u}")"
  if [ "$base_sha" != "$local_sha" ]; then
    ui_err "secret-upgrade: local branch master has diverged from origin."
    echo "  resolve manually (git pull --rebase / git log @..@{u})." >&2
    exit 1
  fi

  old_sha="$local_sha"
  git pull --ff-only --quiet origin master
  new_sha="$(git rev-parse HEAD)"
  refresh_symlinks
  if [ "$old_sha" = "$new_sha" ]; then
    ui_ok "already up to date"
  else
    ui_ok "upgraded: ${old_sha:0:9}..${new_sha:0:9}"
  fi
  exit 0
fi

if [ "$mode" = "ref" ]; then
  git fetch --tags --quiet origin
  old_ref="$(git describe --tags --always)"
  git checkout --quiet "$ref"
  new_ref="$(git describe --tags --always)"
  refresh_symlinks
  if [ "$old_ref" = "$new_ref" ]; then
    ui_info "already on $ref"
  else
    ui_ok "pinned to $ref"
  fi
  exit 0
fi

git fetch --tags --quiet origin
latest="$(latest_tag)"
if [ -z "$latest" ]; then
  ui_info "no released tags found; use --track master"
  exit 0
fi

current="$(git describe --tags --exact-match 2>/dev/null || echo "")"
if [ "$current" = "$latest" ]; then
  ui_info "Already on $latest"
  exit 0
fi

git checkout --quiet "$latest"
refresh_symlinks
ui_ok "Upgraded to $latest"
