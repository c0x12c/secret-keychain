#!/bin/bash
# Remove a secret from the isolated keychain (default: ai.keychain).
# Usage: secret-rm [-f] <NAME>
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

usage() {
  cat >&2 <<'EOF'
usage: secret-rm [-f] <NAME>   remove a secret from the keychain
  -f, --force   skip the confirmation prompt
EOF
}

force=0
name=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -f|--force|--yes) force=1; shift ;;
    --) shift; name="${1:-$name}"; break ;;
    -*) ui_err "secret-rm: unknown option: $1"; usage; exit 64 ;;
    *)  name="$1"; shift ;;
  esac
done

if [ -z "$name" ]; then
  usage
  exit 64
fi

# Confirm only for an interactive human; pipes/automation/tests proceed.
if [ "$force" -eq 0 ] && [ -t 0 ]; then
  ui_confirm "Remove $name from $keychain?" || { ui_info "aborted"; exit 0; }
fi

if ! security delete-generic-password -a "$USER" -s "$name" "$keychain" >/dev/null 2>&1; then
  ui_err "secret-rm: '$name' not found in $keychain"
  exit 1
fi

ui_ok "removed: $name ($keychain)"
