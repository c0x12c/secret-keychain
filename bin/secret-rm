#!/bin/bash
# Remove a secret from the isolated keychain (default: ai.keychain).
# Usage: secret-rm <NAME>
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  echo "usage: secret-rm <NAME>" >&2
  exit 64
fi

name="$1"

if ! security delete-generic-password -a "$USER" -s "$name" "$keychain" >/dev/null 2>&1; then
  echo "secret-rm: '$name' not found in $keychain" >&2
  exit 1
fi

echo "removed: $name ($keychain)" >&2
