#!/bin/bash
# Configure the secret-keychain auto-lock timeout (and, in v1, only that).
#
# DESIGN RULE — binding on any future key:
#   No key in `secret-config` may hold a secret value. Secrets live in the
#   keychain. Future keys hold names, durations, or paths — never tokens.
#
# Usage:
#   secret-config <duration>            set timeout (cap 15m without --force)
#   secret-config <duration> --force    allow up to 4h, logs to state log
#   secret-config --show                print current timeout
#
set -euo pipefail

KEYCHAIN="${SECRET_KEYCHAIN:-ai.keychain}"
DEFAULT_CAP=900     # 15m
HARD_CAP=14400      # 4h
STATE_DIR="${SECRET_STATE_DIR:-$HOME/.claude/state}"

usage() {
  cat <<'EOF' >&2
usage: secret-config <duration>           set timeout (cap 15m)
       secret-config <duration> --force   up to 4h, logged
       secret-config --show               print current timeout
duration: 30s | 10m | 2h | <seconds>
EOF
}

show_current() {
  local line secs
  line="$(security show-keychain-info "$KEYCHAIN" 2>&1 || true)"
  secs="$(printf '%s' "$line" | sed -nE 's/.*timeout=([0-9]+)s.*/\1/p')"
  if [ -z "$secs" ]; then
    echo "secret-config: could not read timeout for $KEYCHAIN" >&2
    return 1
  fi
  echo "$KEYCHAIN: timeout=${secs}s"
}

case "${1:-}" in
  ""|-h|--help) usage; exit 64 ;;
  --show) show_current; exit $? ;;
esac

# --- Set path -------------------------------------------------------------

parse_duration() {
  # Echo seconds for: <int>, <int>s, <int>m, <int>h.
  # Return 64 on a malformed input.
  local raw="$1"
  if [[ "$raw" =~ ^([0-9]+)([smh]?)$ ]]; then
    local n="${BASH_REMATCH[1]}" u="${BASH_REMATCH[2]}"
    case "$u" in
      ""|s) echo "$n" ;;
      m)    echo $(( n * 60 )) ;;
      h)    echo $(( n * 3600 )) ;;
    esac
    return 0
  fi
  return 64
}

dur="$1"
force=0
if [ "${2:-}" = "--force" ]; then force=1; fi

if ! secs="$(parse_duration "$dur")"; then
  echo "secret-config: invalid duration '$dur' (use 30s, 10m, 2h, or seconds)" >&2
  exit 64
fi

if [ "$secs" -le 0 ]; then
  echo "secret-config: duration must be > 0 (never-lock disabled by design)" >&2
  exit 1
fi

if [ "$secs" -gt "$HARD_CAP" ]; then
  echo "secret-config: $dur exceeds 4h hard cap" >&2
  exit 1
fi

if [ "$secs" -gt "$DEFAULT_CAP" ] && [ "$force" -eq 0 ]; then
  echo "secret-config: $dur exceeds 15m cap; pass --force (logged) to override" >&2
  exit 1
fi

if [ "$force" -eq 1 ] && [ "$secs" -gt "$DEFAULT_CAP" ]; then
  reason="${SECRET_FORCE_REASON:-}"
  if [ -z "$reason" ] && [ -t 0 ]; then
    read -r -p "Reason for >15m timeout: " reason || reason=""
  fi
  [ -z "$reason" ] && reason="unspecified"
  reason="${reason//\"/}"

  prev_line="$(security show-keychain-info "$KEYCHAIN" 2>&1 || true)"
  prev_secs="$(printf '%s' "$prev_line" | sed -nE 's/.*timeout=([0-9]+)s.*/\1/p')"
  [ -z "$prev_secs" ] && prev_secs="?"

  mkdir -p "$STATE_DIR"
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  user="${USER:-$(id -un 2>/dev/null || echo unknown)}"
  printf '%s %s forced timeout=%ss (was %ss) reason="%s"\n' \
    "$ts" "$user" "$secs" "$prev_secs" "$reason" \
    >> "$STATE_DIR/secret-config.log"
fi

security set-keychain-settings -t "$secs" -l "$KEYCHAIN"
echo "$KEYCHAIN: timeout set to ${secs}s"
