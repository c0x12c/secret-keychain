#!/bin/bash
# Add or update a secret in the isolated keychain (default: ai.keychain).
# Usage: secret-add [-f] <NAME>
#
# Exposure notes:
#   - Terminal: stty -echo prevents the value appearing on screen
#   - Shell history: no positional value arg — the value never touches history
#   - Shell memory: value lives in $value briefly, unset immediately after
#   - argv: security(1) needs -w VALUE as an argument, so the value is briefly
#     visible in `ps` for the duration of the call (~ms). Use secret-paste
#     (clipboard) for high-value credentials to avoid argv exposure.
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
__lib="$(cd -P "$(dirname "$__self")/../lib" && pwd)"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$__lib/ui.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/update.sh
. "$__lib/update.sh"
__repo="$(cd -P "$(dirname "$__self")/.." && pwd)"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

usage() {
  cat >&2 <<'EOF'
usage: secret-add [-f] <NAME>   add or update a secret (prompted, hidden input)
  -f, --force   overwrite an existing secret without confirming
The value is read from a hidden prompt; it never touches argv or shell history.
EOF
}

force=0
name=""
while [ $# -gt 0 ]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    -f|--force|--yes) force=1; shift ;;
    --) shift; name="${1:-$name}"; break ;;
    -*) ui_err "secret-add: unknown option: $1"; usage; exit 64 ;;
    *)  name="$1"; shift ;;
  esac
done

if [ -z "$name" ]; then
  usage
  exit 64
fi

# Does it already exist? Drives the create-vs-update message and the overwrite
# confirm, so a human sees that the old value (which secret-add does NOT archive)
# is about to be lost. secret-rotate is the archiving path.
exists=0
if security find-generic-password -a "$USER" -s "$name" "$keychain" >/dev/null 2>&1; then
  exists=1
fi

if [ "$exists" -eq 1 ] && [ "$force" -eq 0 ] && [ -t 0 ]; then
  ui_warn "secret-add: '$name' already exists; its value will be replaced (not archived)."
  ui_confirm "Overwrite $name?" || { ui_info "aborted"; exit 0; }
fi

printf "value for %s: " "$name" >&2
stty -echo
IFS= read -r value
stty echo
printf "\n" >&2

if [ -z "$value" ]; then
  ui_err "secret-add: empty value, aborting"
  exit 1
fi

# Clear the value from the shell's symbol table on any exit path — including a
# `security` failure under `set -e`. (Caveat: this does not zero the memory
# pages; the kernel only does that on process exit.)
trap 'unset value' EXIT

security add-generic-password -U -a "$USER" -s "$name" -w "$value" "$keychain"
if [ "$exists" -eq 1 ]; then
  ui_ok "updated: $name ($keychain)"
else
  ui_ok "stored: $name ($keychain)"
fi

secret_update_check "$__repo"
