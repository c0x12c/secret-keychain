#!/bin/bash
# Show the secret audit log without exposing secret values inline.
# Usage: secret-audit [--all|--blocks]
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

state_dir="${SECRET_STATE_DIR:-$HOME/.claude/state}"
logfile="${SECRET_AUDIT_LOG:-$state_dir/secret-audit.log}"

usage() {
  cat >&2 <<'EOF'
usage: secret-audit [--all|--blocks]
  (no flag)   show the last 50 audit entries
  --all       show the entire log
  --blocks    show only blocked-inline events
  -h, --help  show this help
EOF
}

if [ $# -gt 1 ]; then
  usage
  exit 64
fi

case "${1:-}" in
  ""|--all|--blocks) ;;
  -h|--help) usage; exit 0 ;;
  *)
    usage
    exit 64
    ;;
esac

[ -f "$logfile" ] || {
  ui_info "(no audit log yet)"
  exit 0
}

case "${1:-}" in
  --all) cat "$logfile" ;;
  --blocks) grep 'BLOCKED_INLINE' "$logfile" ;;
  *) tail -50 "$logfile" ;;
esac
