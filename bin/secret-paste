#!/bin/bash
# Store a secret from the clipboard into the isolated keychain, then clear it.
# Usage: secret-paste <NAME>
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"
name="${1:?usage: secret-paste <NAME>}"
value="$(pbpaste)"

if [ -z "$value" ]; then
  echo "secret-paste: clipboard is empty" >&2
  exit 1
fi

security add-generic-password -U -a "$USER" -s "$name" -w "$value" "$keychain"
echo "stored: $name (from clipboard, $keychain)" >&2
pbcopy < /dev/null
echo "clipboard cleared" >&2
