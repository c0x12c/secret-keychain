#!/bin/bash
# Store a secret from the clipboard into the isolated keychain, then clear it.
# Usage: secret-paste <NAME>
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"

case "${1:-}" in
  -h|--help)
    echo "usage: secret-paste <NAME>   store the clipboard's contents, then clear it" >&2
    exit 0
    ;;
esac

if [ $# -ne 1 ] || [ -z "${1:-}" ]; then
  echo "usage: secret-paste <NAME>" >&2
  exit 64
fi

name="$1"
value="$(pbpaste)"

if [ -z "$value" ]; then
  ui_err "secret-paste: clipboard is empty"
  exit 1
fi

exists=0
if security find-generic-password -a "$USER" -s "$name" "$keychain" >/dev/null 2>&1; then
  exists=1
fi

security add-generic-password -U -a "$USER" -s "$name" -w "$value" "$keychain"
if [ "$exists" -eq 1 ]; then
  ui_ok "updated: $name (from clipboard, $keychain)"
else
  ui_ok "stored: $name (from clipboard, $keychain)"
fi
pbcopy < /dev/null
ui_info "clipboard cleared"
