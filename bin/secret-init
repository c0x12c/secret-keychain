#!/bin/bash
# Bootstrap the isolated keychain used by the secret tools.
# Creates it if missing and sets an idle autolock. Safe to re-run.
# Usage: secret-init
# Env:
#   SECRET_KEYCHAIN          keychain name (default: ai.keychain)
#   SECRET_AUTOLOCK_SECONDS  idle/sleep lock timeout in seconds (default: 300)
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
__lib="$(cd -P "$(dirname "$__self")/../lib" && pwd)"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$__lib/ui.sh"
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/update.sh
. "$__lib/update.sh"
__repo="$(cd -P "$(dirname "$__self")/.." && pwd)"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"
timeout="${SECRET_AUTOLOCK_SECONDS:-300}"

case "${1:-}" in
  -h|--help)
    echo "usage: secret-init   create the isolated keychain and set its autolock (run once)" >&2
    exit 0
    ;;
esac

if security show-keychain-info "$keychain" >/dev/null 2>&1; then
  ui_info "keychain $keychain already exists"
else
  ui_info "creating $keychain (you will be prompted for a keychain password)"
  security create-keychain "$keychain"
fi

# -l lock on sleep, -u lock after idle timeout, -t timeout in seconds
security set-keychain-settings -l -u -t "$timeout" "$keychain"
ui_ok "initialized $keychain (autolock after ${timeout}s idle / on sleep)"

secret_update_check "$__repo"
