#!/bin/bash
# Bootstrap the isolated keychain used by the secret tools.
# Creates it if missing and sets an idle autolock. Safe to re-run.
# Usage: secret-init
# Env:
#   SECRET_KEYCHAIN          keychain name (default: ai.keychain)
#   SECRET_AUTOLOCK_SECONDS  idle/sleep lock timeout in seconds (default: 300)
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"
timeout="${SECRET_AUTOLOCK_SECONDS:-300}"

if security show-keychain-info "$keychain" >/dev/null 2>&1; then
  echo "keychain $keychain already exists" >&2
else
  echo "creating $keychain (you will be prompted for a keychain password)" >&2
  security create-keychain "$keychain"
fi

# -l lock on sleep, -u lock after idle timeout, -t timeout in seconds
security set-keychain-settings -l -u -t "$timeout" "$keychain"
echo "initialized $keychain (autolock after ${timeout}s idle / on sleep)" >&2
