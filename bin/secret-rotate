#!/bin/bash
# Rotate a stored secret while archiving the previous value for rollback.
# Usage: secret-rotate <NAME> [--from-clipboard]
set -euo pipefail

keychain="${SECRET_KEYCHAIN:-ai.keychain}"
state_dir="${SECRET_STATE_DIR:-$HOME/.claude/state}"
logfile="${SECRET_AUDIT_LOG:-$state_dir/secret-audit.log}"

if [ $# -lt 1 ] || [ $# -gt 2 ] || [ -z "${1:-}" ]; then
  echo "usage: secret-rotate <NAME> [--from-clipboard]" >&2
  exit 64
fi

name="$1"
from_clipboard="${2:-}"
if [ -n "$from_clipboard" ] && [ "$from_clipboard" != "--from-clipboard" ]; then
  echo "usage: secret-rotate <NAME> [--from-clipboard]" >&2
  exit 64
fi

if ! old_value="$(security find-generic-password -a "$USER" -s "$name" -w "$keychain" 2>/dev/null)"; then
  echo "secret-rotate: '$name' not found in $keychain" >&2
  exit 1
fi

archive_name="${name}__rotated_$(date +%Y%m%d%H%M%S)"
security add-generic-password -a "$USER" -s "$archive_name" -w "$old_value" "$keychain" >/dev/null
echo "archived: $archive_name" >&2

if [ "$from_clipboard" = "--from-clipboard" ]; then
  new_value="$(pbpaste)"
  if [ -z "$new_value" ]; then
    echo "secret-rotate: clipboard is empty" >&2
    exit 1
  fi
  pbcopy < /dev/null
else
  printf "new value for %s: " "$name" >&2
  stty -echo
  IFS= read -r new_value
  stty echo
  printf "\n" >&2
fi

if [ -z "$new_value" ]; then
  echo "secret-rotate: empty value, aborting" >&2
  exit 1
fi

security add-generic-password -U -a "$USER" -s "$name" -w "$new_value" "$keychain" >/dev/null
mkdir -p "$(dirname "$logfile")"
echo "$(date '+%Y-%m-%d %H:%M:%S') ROTATED name=$name" >> "$logfile"
echo "rotated: $name" >&2
