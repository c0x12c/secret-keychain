#!/bin/bash
# Rotate a stored secret while archiving the previous value for rollback.
# Usage: secret-rotate <NAME> [--from-clipboard]
set -euo pipefail

# Load shared UI helpers (follow the install symlink back to the repo).
__self="${BASH_SOURCE[0]}"
while [ -L "$__self" ]; do
  __link="$(readlink "$__self")"
  case "$__link" in
    /*) __self="$__link" ;;
    *)  __self="$(cd -P "$(dirname "$__self")" && pwd)/$__link" ;;
  esac
done
# shellcheck source-path=SCRIPTDIR
# shellcheck source=../lib/ui.sh
. "$(cd -P "$(dirname "$__self")/../lib" && pwd)/ui.sh"

keychain="${SECRET_KEYCHAIN:-ai.keychain}"
state_dir="${SECRET_STATE_DIR:-$HOME/.claude/state}"
logfile="${SECRET_AUDIT_LOG:-$state_dir/secret-audit.log}"

usage() {
  cat >&2 <<'EOF'
usage: secret-rotate <NAME> [--from-clipboard]
Replace a secret's value, archiving the previous value as NAME__rotated_<ts>
for rollback. New value is read from a hidden prompt, or from the clipboard
with --from-clipboard.
EOF
}

case "${1:-}" in
  -h|--help) usage; exit 0 ;;
esac

if [ $# -lt 1 ] || [ $# -gt 2 ] || [ -z "${1:-}" ]; then
  usage
  exit 64
fi

name="$1"
from_clipboard="${2:-}"
if [ -n "$from_clipboard" ] && [ "$from_clipboard" != "--from-clipboard" ]; then
  usage
  exit 64
fi

if ! old_value="$(security find-generic-password -a "$USER" -s "$name" -w "$keychain" 2>/dev/null)"; then
  ui_err "secret-rotate: '$name' not found in $keychain"
  exit 1
fi

archive_name="${name}__rotated_$(date +%Y%m%d%H%M%S)"
security add-generic-password -a "$USER" -s "$archive_name" -w "$old_value" "$keychain" >/dev/null
ui_info "archived: $archive_name"

if [ "$from_clipboard" = "--from-clipboard" ]; then
  new_value="$(pbpaste)"
  if [ -z "$new_value" ]; then
    ui_err "secret-rotate: clipboard is empty"
    exit 1
  fi
  pbcopy < /dev/null
else
  printf "new value for %s: " "$name" >&2
  stty -echo
  IFS= read -r new_value
  stty echo
  printf "\n" >&2
fi

if [ -z "$new_value" ]; then
  ui_err "secret-rotate: empty value, aborting"
  exit 1
fi

security add-generic-password -U -a "$USER" -s "$name" -w "$new_value" "$keychain" >/dev/null
mkdir -p "$(dirname "$logfile")"
echo "$(date '+%Y-%m-%d %H:%M:%S') ROTATED name=$name" >> "$logfile"
ui_ok "rotated: $name"
