{
  "//": "secret-keychain agent guardrails - merge into .claude/settings.json (project) or ~/.claude/settings.json (user). See agent/AGENTS.md.",
  "permissions": {
    "allow": [
      "Bash(secret)",
      "Bash(secret *)",
      "Bash(secret-list)",
      "Bash(secret-audit)",
      "Bash(secret-audit *)"
    ],
    "deny": [
      "Bash(secret-add)",
      "Bash(secret-add *)",
      "Bash(secret-paste)",
      "Bash(secret-paste *)",
      "Bash(secret-rm)",
      "Bash(secret-rm *)",
      "Bash(secret-load)",
      "Bash(secret-load *)",
      "Bash(secret-rotate)",
      "Bash(secret-rotate *)",
      "Bash(secret-upgrade)",
      "Bash(secret-upgrade *)",
      "Bash(secret-config)",
      "Bash(secret-config *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/secret-gate.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/secret-gate-write.sh"
          }
        ]
      }
    ]
  }
}
