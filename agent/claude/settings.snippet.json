{
  "//": "secret-keychain agent guardrails — merge into .claude/settings.json (project) or ~/.claude/settings.json (user). See agent/AGENTS.md.",
  "permissions": {
    "allow": [
      "Bash(secret)",
      "Bash(secret *)",
      "Bash(secret-list)"
    ],
    "deny": [
      "Bash(secret-add)",
      "Bash(secret-add *)",
      "Bash(secret-paste)",
      "Bash(secret-paste *)",
      "Bash(secret-rm)",
      "Bash(secret-rm *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/secret-gate.sh"
          }
        ]
      }
    ]
  }
}
