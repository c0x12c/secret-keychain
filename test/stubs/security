#!/bin/bash
# Hermetic stub of macOS `security` for tests. File-backed at $SECRET_STORE.
# Implements only the subcommands secret-keychain uses. Store lines: NAME<TAB>VALUE.
set -eu

store="${SECRET_STORE:?SECRET_STORE not set}"
touch "$store"
cmd="${1:-}"
shift || true

# get_field FLAG ARGS... -> prints the value following FLAG
get_field() {
  local want="$1"
  shift
  while [ "$#" -gt 0 ]; do
    if [ "$1" = "$want" ]; then
      printf '%s' "${2:-}"
      return 0
    fi
    shift
  done
}

case "$cmd" in
  add-generic-password)
    svc="$(get_field -s "$@")"
    val="$(get_field -w "$@")"
    grep -v "^${svc}	" "$store" > "$store.tmp" 2>/dev/null || true
    mv "$store.tmp" "$store"
    printf '%s\t%s\n' "$svc" "$val" >> "$store"
    ;;
  find-generic-password)
    svc="$(get_field -s "$@")"
    line="$(grep "^${svc}	" "$store" 2>/dev/null || true)"
    [ -n "$line" ] || exit 1
    printf '%s\n' "${line#*	}"
    ;;
  delete-generic-password)
    svc="$(get_field -s "$@")"
    grep -q "^${svc}	" "$store" 2>/dev/null || exit 1
    grep -v "^${svc}	" "$store" > "$store.tmp" 2>/dev/null || true
    mv "$store.tmp" "$store"
    ;;
  dump-keychain)
    while IFS=$'\t' read -r svc _; do
      printf '    "svce"<blob>="%s"\n' "$svc"
    done < "$store"
    ;;
  set-keychain-settings)
    # Parse: set-keychain-settings -t <seconds> [-l] <keychain>
    secs=""; kc=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        -t) secs="$2"; shift 2 ;;
        -l) shift ;;
        *)  kc="$1"; shift ;;
      esac
    done
    : "${kc:=${SECRET_KEYCHAIN:-test.keychain}}"
    : "${SECRET_TIMEOUT_STORE:=$SECRET_STORE.timeout}"
    printf '%s\t%s\n' "$kc" "${secs:-0}" > "$SECRET_TIMEOUT_STORE"
    ;;
  show-keychain-info)
    [ "${SECRET_KEYCHAIN_EXISTS:-1}" = "1" ] || exit 1
    kc="${1:-${SECRET_KEYCHAIN:-test.keychain}}"
    : "${SECRET_TIMEOUT_STORE:=$SECRET_STORE.timeout}"
    secs=300
    if [ -f "$SECRET_TIMEOUT_STORE" ]; then
      val="$(awk -F'\t' -v k="$kc" '$1==k {print $2; exit}' "$SECRET_TIMEOUT_STORE")"
      [ -n "$val" ] && secs="$val"
    fi
    # Real macOS writes to stderr.
    printf 'Keychain "%s" lock-on-sleep timeout=%ss\n' "$kc" "$secs" >&2
    ;;
  create-keychain|list-keychains)
    : # no-op for the stub
    ;;
  *)
    : # ignore anything else
    ;;
esac
